root = true

[*]
charset = utf-8
end_of_line = lf
indent_style = space
indent_size = 4
insert_final_newline = true
trim_trailing_whitespace = true

[{*.kt,*.kts}]
ij_kotlin_code_style_defaults = KOTLIN_OFFICIAL

[*.xml]
ij_continuation_indent_size = 4

[{*.yml,*.yaml}]
indent_size = 2

[*.md]
trim_trailing_whitespace = false
